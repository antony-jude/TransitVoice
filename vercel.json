{
  "version": 2,
  "routes": [
    {
      "src": "/api/reports/resolve",
      "dest": "/api/reports/resolve.js"
    },
    {
      "src": "/api/reports",
      "dest": "/api/reports/index.js"
    },
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
